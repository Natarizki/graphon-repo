#!/bin/bash
# graphon - CLI wrapper with Unix Domain Socket & Memory Optimization

GRAPHON_HOME="$HOME/.graphon"
GROOVY_SCRIPT="$GRAPHON_HOME/lib/graphon.groovy"
SOCKET_FILE="$GRAPHON_HOME/daemon.sock"
DAEMON_PID_FILE="$GRAPHON_HOME/daemon.pid"
LOG_FILE="$GRAPHON_HOME/daemon.log"

if [ ! -f "$GROOVY_SCRIPT" ]; then
    echo "Error: Graphon engine not found in $GROOVY_SCRIPT"
    exit 1
fi

ARCH=$(uname -m)
JRE_DIR="$GRAPHON_HOME/jre"
if [ -d "$JRE_DIR/bin" ]; then
    export JAVA_HOME="$JRE_DIR"
    export PATH="$JAVA_HOME/bin:$PATH"
else
    if ! command -v java &> /dev/null; then
        echo "Error: Java is not installed. Please install JDK."
        exit 1
    fi
fi

export JAVA_OPTS="-XX:+UseSerialGC -XX:MaxMetaspaceSize=128m -Xms16m -Xmx256m -Xshare:auto"

is_daemon_running() {
    if [ -f "$DAEMON_PID_FILE" ]; then
        PID=$(cat "$DAEMON_PID_FILE")
        if kill -0 "$PID" 2>/dev/null; then
            if [ -S "$SOCKET_FILE" ]; then
                return 0
            fi
        fi
    fi
    if [ -f "$DAEMON_PID_FILE" ]; then
        kill $(cat "$DAEMON_PID_FILE") 2>/dev/null
        rm -f "$DAEMON_PID_FILE"
    fi
    return 1
}

start_daemon() {
    nohup groovy "$GROOVY_SCRIPT" --daemon > "$LOG_FILE" 2>&1 &
    echo $! > "$DAEMON_PID_FILE"
    echo "Waiting for Graphon daemon to start..."
    for i in {1..30}; do
        if [ -S "$SOCKET_FILE" ]; then
            echo "Daemon is ready."
            return 0
        fi
        sleep 0.5
    done
    echo "Error: Daemon failed to start. Check $LOG_FILE"
    return 1
}

case "$1" in
    "init"|"setup-android"|"--version"|"-v"|"--help"|"-h")
        groovy "$GROOVY_SCRIPT" "$@"
        exit $?
        ;;
    "daemon:stop"|"exit")
        if is_daemon_running; then
            PID=$(cat "$DAEMON_PID_FILE")
            echo "Stopping daemon (PID: $PID)..."
            echo "cwd:$PWD task:shutdown" | nc -U -w 2 "$SOCKET_FILE" 2>/dev/null
            kill "$PID" 2>/dev/null
            rm -f "$DAEMON_PID_FILE" "$SOCKET_FILE"
            echo "Daemon stopped."
        else
            echo "Daemon not running."
        fi
        exit 0
        ;;
    "daemon:status"|"status")
        if is_daemon_running; then
            echo "Daemon running (PID: $(cat $DAEMON_PID_FILE))"
        else
            echo "Daemon not running."
        fi
        exit 0
        ;;
    "daemon:restart")
        $0 daemon:stop
        sleep 1
        $0 daemon:start
        exit 0
        ;;
    "daemon:start")
        if is_daemon_running; then
            echo "Daemon already running."
            exit 0
        fi
        echo "Starting Graphon daemon..."
        start_daemon
        exit 0
        ;;
esac

if ! is_daemon_running; then
    echo "Starting Graphon daemon..."
    start_daemon
fi

COMMAND="$*"
if [ -z "$COMMAND" ]; then
    COMMAND="default"
fi

CWD="$PWD"

# PERBAIKAN: Hapus -q 1 agar netcat tidak nunggu 1 detik.
# Daemon akan otomatis nutup koneksi setelah ngirim "END_OF_OUTPUT", jadi netcat bakal langsung exit.
echo "cwd:$CWD task:$COMMAND" | nc -U -w 60 "$SOCKET_FILE"

if [ $? -ne 0 ]; then
    echo "Error: Cannot connect to daemon. Try: graphon daemon:restart"
    exit 1
fi
