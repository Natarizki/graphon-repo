#!/bin/bash
# graphon - Cross-Platform CLI Wrapper (Support ARM64 & x86_64)

PORT=9876
DAEMON_PID_FILE=".graphon_daemon.pid"
LOG_FILE=".graphon_daemon.log"

# 1. DETEKSI LOKASI INSTALASI GRAPHON (~/.graphon/)
GRAPHON_HOME="$HOME/.graphon"
GROOVY_SCRIPT="$GRAPHON_HOME/lib/graphon.groovy"

if [ ! -f "$GROOVY_SCRIPT" ]; then
    echo "Error: Graphon engine not found in $GROOVY_SCRIPT"
    echo "Please run the installer first: ./install.sh"
    exit 1
fi

# 2. DETEKSI ARSITEKTUR SISTEM
ARCH=$(uname -m)

# 3. GUNAKAN CUSTOM JRE DI ~/.graphon/jre/ JIKA ADA
JRE_DIR="$GRAPHON_HOME/jre"
if [ -d "$JRE_DIR/bin" ]; then
    export JAVA_HOME="$JRE_DIR"
    export PATH="$JAVA_HOME/bin:$PATH"
else
    # Fallback ke Java/Groovy sistem (wajib ada di PATH)
    if ! command -v java &> /dev/null; then
        echo "Error: Java is not installed. Please install JDK."
        exit 1
    fi
fi

# 4. JVM Optimization Flags
export JAVA_OPTS="-XX:+UseSerialGC -XX:MaxMetaspaceSize=128m -Xms16m -Xmx256m -Xshare:auto"

is_daemon_running() {
    if [ -f "$GRAPHON_HOME/$DAEMON_PID_FILE" ]; then
        PID=$(cat "$GRAPHON_HOME/$DAEMON_PID_FILE")
        if kill -0 "$PID" 2>/dev/null; then
            return 0
        fi
    fi
    return 1
}

start_daemon() {
    nohup groovy "$GROOVY_SCRIPT" --daemon > "$GRAPHON_HOME/$LOG_FILE" 2>&1 &
    echo $! > "$GRAPHON_HOME/$DAEMON_PID_FILE"
    echo "Waiting for Graphon daemon to start..."
    for i in {1..60}; do
        if nc -z -w 1 127.0.0.1 $PORT 2>/dev/null; then
            echo "Daemon is ready."
            return 0
        fi
        sleep 0.5
    done
    return 1
}

# Tangkap perintah khusus yang bypass daemon
case "$1" in
    "init")
        groovy "$GROOVY_SCRIPT" "$@"
        exit $?
        ;;
    "setup-android")
        groovy "$GROOVY_SCRIPT" "$@"
        exit $?
        ;;
    "--version"|"-v")
        groovy "$GROOVY_SCRIPT" "$@"
        exit $?
        ;;
    "--help"|"-h")
        groovy "$GROOVY_SCRIPT" "$@"
        exit $?
        ;;
    "daemon:stop"|"exit")
        if is_daemon_running; then
            PID=$(cat "$GRAPHON_HOME/$DAEMON_PID_FILE")
            echo "Stopping daemon (PID: $PID)..."
            echo "cwd:$PWD task:shutdown" | nc -w 2 -q 0 127.0.0.1 $PORT > /dev/null 2>&1
            kill "$PID" 2>/dev/null
            rm -f "$GRAPHON_HOME/$DAEMON_PID_FILE"
            echo "Daemon stopped."
        else
            echo "Daemon not running."
        fi
        exit 0
        ;;
    "daemon:status"|"status")
        if is_daemon_running; then
            echo "Daemon running (PID: $(cat $GRAPHON_HOME/$DAEMON_PID_FILE))"
        else
            echo "Daemon not running."
        fi
        exit 0
        ;;
    "daemon:restart")
        $0 daemon:stop
        sleep 1
        $0 daemon:start
        exit 0
        ;;
    "daemon:start")
        if is_daemon_running; then
            echo "Daemon already running."
            exit 0
        fi
        echo "Starting Graphon daemon..."
        start_daemon
        exit 0
        ;;
esac

if ! is_daemon_running; then
    echo "Starting Graphon daemon..."
    start_daemon
fi

COMMAND="$*"
if [ -z "$COMMAND" ]; then
    COMMAND="default"
fi

CWD="$PWD"
echo "cwd:$CWD task:$COMMAND" | nc -w 60 127.0.0.1 $PORT

if [ $? -ne 0 ]; then
    echo "Error: Cannot connect to daemon. Try: graphon daemon:restart"
    exit 1
fi
